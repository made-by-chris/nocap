{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "NoCap",
  "version": "0.1.1",
  "identifier": "com.nocap.recorder",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5511"
  },
  "app": {
    "windows": [
      {
        "title": "NoCap",
        "width": 1100,
        "height": 750,
        "resizable": true,
        "fullscreen": false,
        "useHttpsScheme": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' blob: data:; connect-src 'self' blob: mediastream: ipc: ipc://localhost; media-src 'self' blob: mediastream:; img-src 'self' blob: data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "infoPlist": "Info.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
